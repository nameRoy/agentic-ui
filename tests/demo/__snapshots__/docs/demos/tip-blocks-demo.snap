<DocumentFragment>
  <div
    class="ant-app"
  >
    <div>
      test
    </div>
    <div
      style="padding: 16px; max-width: 560px;"
    >
      <div
        class="ant-agentic-md-editor markdown-editor ant-agentic-md-editor-readonly"
        style="width: 100%; height: auto;"
      >
        <div
          class="ant-agentic-md-editor-container"
          style="height: 100%;"
          tabindex="-1"
        >
          <div
            autocapitalize="false"
            autocorrect="false"
            class="ant-agentic-md-editor-content ant-agentic-md-editor-content-readonly"
            contenteditable="false"
            data-slate-editor="true"
            data-slate-node="value"
            spellcheck="false"
            style="position: relative; white-space: pre-wrap; word-wrap: break-word;"
            translate="no"
            zindex="-1"
          >
            <div
              class="markdown-container info"
              data-be="blockquote"
              data-slate-node="element"
            >
              <div
                class=""
                data-be="paragraph"
                data-slate-node="element"
              >
                <span
                  data-slate-node="text"
                >
                  <span
                    data-be="text"
                    data-slate-leaf="true"
                    draggable="false"
                  >
                    <span
                      data-slate-string="true"
                    >
                      这是一个信息提示块。
                    </span>
                  </span>
                </span>
              </div>
            </div>
            <div
              class="markdown-container warning"
              data-be="blockquote"
              data-slate-node="element"
            >
              <div
                class=""
                data-be="paragraph"
                data-slate-node="element"
              >
                <span
                  data-slate-node="text"
                >
                  <span
                    data-be="text"
                    data-slate-leaf="true"
                    draggable="false"
                  >
                    <span
                      data-slate-string="true"
                    >
                      这是一个警告提示块。
                    </span>
                  </span>
                </span>
              </div>
            </div>
            <div
              class="markdown-container success"
              data-be="blockquote"
              data-slate-node="element"
            >
              <div
                class=""
                data-be="paragraph"
                data-slate-node="element"
              >
                <span
                  data-slate-node="text"
                >
                  <span
                    data-be="text"
                    data-slate-leaf="true"
                    draggable="false"
                  >
                    <span
                      data-slate-string="true"
                    >
                      这是一个成功提示块。
                    </span>
                  </span>
                </span>
              </div>
            </div>
            <div
              class="markdown-container error"
              data-be="blockquote"
              data-slate-node="element"
            >
              <div
                class=""
                data-be="paragraph"
                data-slate-node="element"
              >
                <span
                  data-slate-node="text"
                >
                  <span
                    data-be="text"
                    data-slate-leaf="true"
                    draggable="false"
                  >
                    <span
                      data-slate-string="true"
                    >
                      这是一个错误提示块。
                    </span>
                  </span>
                </span>
              </div>
            </div>
            <div
              class="markdown-container tip"
              data-be="blockquote"
              data-slate-node="element"
            >
              <div
                class="markdown-container__title"
              >
                提示
              </div>
              <div
                class=""
                data-be="paragraph"
                data-slate-node="element"
              >
                <span
                  data-slate-node="text"
                >
                  <span
                    data-be="text"
                    data-slate-leaf="true"
                    draggable="false"
                  >
                    <span
                      data-slate-string="true"
                    >
                      这是一条带标题的提示块。
                    </span>
                  </span>
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</DocumentFragment>