<DocumentFragment>
  <div
    class="ant-app"
  >
    <div>
      test
    </div>
    <div
      style="border-radius: var(--radius-modal-base); background: var(color-gray-bg-page-light); box-shadow: var(--shadow-control-base); width: min(830px,100%); display: flex; flex-direction: column; justify-content: space-between; padding: 0px; z-index: 0; margin: 24px auto;"
    >
      <div
        style="padding: 16px; display: flex; flex-direction: row; align-items: center; box-sizing: border-box; border-width: 0px 0px 1px 0px; border-style: solid; border-color: rgba(0, 16, 32, 0.063);"
      >
        <span
          style="font-size: 13px; color: rgba(0, 0, 0, 0.45);"
        >
          🤔 思考中（DOM 轻量加载）
        </span>
        <div
          style="font-size: 12px; color: rgba(0, 0, 0, 0.45);"
        >
          切换状态查看 Bubble 在思考中分支的纯 DOM 加载效果（文本 + dots）
        </div>
      </div>
      <div>
        <div
          style="padding: 16px;"
        >
          <div
            class="ant-space ant-space-horizontal ant-space-align-center ant-space-gap-row-small ant-space-gap-col-small"
            style="margin-bottom: 12px;"
          >
            <div
              class="ant-space-item"
            >
              <span>
                思考状态：
              </span>
            </div>
            <div
              class="ant-space-item"
            >
              <button
                aria-checked="true"
                class="ant-switch ant-switch-checked"
                role="switch"
                type="button"
              >
                <div
                  class="ant-switch-handle"
                />
                <span
                  class="ant-switch-inner"
                >
                  <span
                    class="ant-switch-inner-checked"
                  >
                    思考中
                  </span>
                  <span
                    class="ant-switch-inner-unchecked"
                  >
                    已完成
                  </span>
                </span>
              </button>
            </div>
            <div
              class="ant-space-item"
            >
              <button
                class="ant-btn ant-btn-default ant-btn-color-default ant-btn-variant-outlined"
                type="button"
              >
                <span>
                  切换状态
                </span>
              </button>
            </div>
          </div>
          <div
            class="ant-agentic-bubble ant-agentic-bubble-left ant-agentic-bubble-ai ant-flex ant-flex-align-stretch ant-flex-vertical"
            style="gap: 12px;"
          >
            <div
              class="ant-agentic-bubble-container ant-agentic-bubble-container-left ant-agentic-bubble-container-pure"
            >
              <div
                class="ant-agentic-bubble-avatar-title ant-agentic-bubble-avatar-title-left ant-agentic-bubble-avatar-title-ai ant-agentic-bubble-avatar-title-pure"
                data-testid="bubble-avatar-title"
              >
                <span
                  class="ant-avatar ant-avatar-circle ant-avatar-image ant-agentic-bubble-avatar"
                  data-testid="bubble-avatar"
                  style="width: 24px; height: 24px; font-size: 18px; cursor: default;"
                >
                  <img
                    alt="avatar"
                    src="https://mdn.alipayobjects.com/huamei_re70wt/afts/img/A*ed7ZTbwtgIQAAAAAQOAAAAgAemuEAQ/original"
                  />
                </span>
                <div
                  class="ant-agentic-bubble-title ant-flex"
                  data-testid="bubble-title"
                  style="flex-direction: row; display: flex; align-items: center; gap: 8px;"
                >
                  <span>
                    AI 助手
                  </span>
                  <time
                    class="ant-agentic-bubble-title-time"
                    data-testid="bubble-time"
                  >
                    2024-02-27 17:20:00
                  </time>
                </div>
              </div>
              <div
                class="ant-agentic-bubble-container ant-agentic-bubble-container-left ant-agentic-bubble-container-ai ant-agentic-bubble-container-pure"
                data-testid="chat-message"
                style="display: flex; gap: 4px; flex-direction: column; align-items: flex-start;"
              >
                <div
                  class="ant-agentic-bubble-content ant-agentic-bubble-content-left ant-agentic-bubble-content-ai ant-agentic-bubble-content-pure"
                  data-testid="message-content"
                  style="min-width: 0px;"
                >
                  <div
                    aria-atomic="true"
                    aria-label="思考中..."
                    aria-live="polite"
                    class="agent-item-default-content ant-agentic-ui-display-messages-content-loading ant-agentic-ui-display-messages-content-loading-default"
                    data-testid="message-content"
                    role="status"
                  >
                    <span
                      aria-hidden="true"
                      class="ant-agentic-ui-display-messages-content-loading-dots"
                      data-testid="message-thinking-dots"
                    >
                      <span
                        class="ant-agentic-ui-display-messages-content-loading-dot"
                        data-testid="message-thinking-dot"
                      />
                      <span
                        class="ant-agentic-ui-display-messages-content-loading-dot"
                        data-testid="message-thinking-dot"
                      />
                      <span
                        class="ant-agentic-ui-display-messages-content-loading-dot"
                        data-testid="message-thinking-dot"
                      />
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</DocumentFragment>